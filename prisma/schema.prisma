generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  timezone           String   @default("Africa/Nairobi")
  shopifyDomain      String?  @unique
  shopifyAccessToken String?
  currency           String   @default("KES")
  createdAt          DateTime @default(now())

  products           Product[]
  salesHistory       SalesHistory[]
  predictions        Prediction[]
  orders             Order[]
  suppliers          Supplier[]
  promos             Promo[]
  monthlyContext     MonthlyContext[]
  memberships        Membership[]
  shopifyConnection  ShopifyConnection?
  locations          Location[]
  inventorySnapshots InventorySnapshot[]
  purchaseOrders     PurchaseOrder[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String // Supabase auth.users UUID — plain String, NO FK (D-13)
  tenantId  String
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Product {
  id                String    @id @default(cuid())
  tenantId          String
  shopifyProductId  String
  shopifyVariantId  String
  sku               String
  title             String
  vendor            String?
  productType       String?
  priceKes          Float     @default(0)
  costKes           Float     @default(0)
  imageUrl          String?
  currentStock      Float     @default(0)
  abcCategory       String?
  dailySalesRate    Float     @default(0)
  lastSynced        DateTime  @default(now())
  supplierId        String?
  onOrder           Int       @default(0)
  expectedArrivalAt DateTime?
  receivedAt        DateTime?
  leadTimeDays      Int?      // per-product lead-time override (days); null → supplier default
  importCategory    String?   // "LOCAL" | "KOREAN" | "WESTERN"; null = unclassified (treated LOCAL)

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier           Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  salesHistory       SalesHistory[]
  predictions        Prediction[]
  inventoryLevels    InventoryLevel[]
  inventorySnapshots InventorySnapshot[]
  purchaseOrderLines PurchaseOrderLine[]

  @@unique([tenantId, shopifyProductId])
  @@index([tenantId])
  @@index([tenantId, productType])
  @@index([tenantId, vendor])
  @@index([tenantId, importCategory])
}

model SalesHistory {
  id         String   @id @default(cuid())
  tenantId   String
  productId  String
  date       DateTime
  quantity   Float
  revenueKes Float
  channel    String   @default("shopify")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date, channel])
  @@index([tenantId, date])
}

model Supplier {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  country         String?
  currency        String   @default("USD")
  leadTimeAvgDays Int      @default(30)
  leadTimeStdDays Int      @default(7)
  moq             Int      @default(1)
  notes           String?
  createdAt       DateTime @default(now())

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
}

model Promo {
  id          String   @id @default(cuid())
  tenantId    String
  startDate   DateTime
  endDate     DateTime
  scope       String   @default("all")
  scopeValue  String?
  discountPct Float    @default(0)
  promoType   String   @default("flash")
  channel     String   @default("all")
  notes       String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, startDate])
}

model MonthlyContext {
  id                  String   @id @default(cuid())
  tenantId            String
  month               String
  marketingBudget     Float?
  promotions          String?
  seasonalExpectation String?
  cashFlow            String?
  notes               String?
  createdAt           DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, month])
}

model Prediction {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  runDate   DateTime @default(now())

  layer1Forecast30d Float
  layer1Confidence  Float
  layer2Adjustment  Float
  finalForecast30d  Float
  daysUntilStockout Int
  recommendedQty    Float
  safetyStock       Float
  reorderPoint      Float
  confidence        Float
  reasoning         String
  urgency           String
  signals           String
  forecastRunId     String  @default(cuid())
  regime            String?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@index([tenantId, runDate])
  @@index([productId, runDate])
  @@index([tenantId, productId, runDate])
}

model Order {
  id                  String    @id @default(cuid())
  tenantId            String
  predictionId        String
  status              String    @default("pending")
  shopifyDraftOrderId String?
  approvedAt          DateTime?
  skipReason          String?
  createdAt           DateTime  @default(now())
  purchaseOrderId     String?

  // Reorder tracking / memory (status "ordered" → "received"). Manual "Mark as ordered"
  // records the intent; suppression rides on these fields, NOT Product.onOrder (the nightly
  // Shopify reconcile authoritatively resets onOrder, which would wipe a manual bump).
  productId         String?
  orderedQty        Int?
  orderedAt         DateTime?
  expectedArrivalAt DateTime?
  receivedAt        DateTime?
  stockAtOrder      Float?
  sawEnroute        Boolean   @default(false)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prediction    Prediction     @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, productId, status])
}

enum Role {
  OWNER
  MEMBER
}

// Required by @shopify/shopify-app-session-storage-prisma@9. Confirm exact field
// set against the adapter README at execute time (Open Question #3).
model Session {
  id          String    @id
  shop        String
  state       String
  isOnline    Boolean   @default(false)
  scope       String?
  expires     DateTime?
  accessToken String?
  userId      BigInt?
}

model ShopifyConnection {
  id            String    @id @default(cuid())
  tenantId      String    @unique
  shopDomain    String    @unique // <store>.myshopify.com
  accessToken   String // AES-256-GCM ciphertext (encrypt()/decrypt())
  scope         String
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  lastSyncOkAt  DateTime? // last successful reconcile (G1 sync-health)
  lastSyncError String?   // message of the last failed reconcile; cleared on success

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Location {
  id                String  @id @default(cuid())
  tenantId          String
  shopifyLocationId String
  name              String
  isPrimary         Boolean @default(false)

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryLevels InventoryLevel[]

  @@unique([tenantId, shopifyLocationId])
  @@index([tenantId])
}

model InventoryLevel {
  id         String   @id @default(cuid())
  tenantId   String
  locationId String
  productId  String
  onHand     Int      @default(0) // on_hand quantity, NOT available
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([tenantId])
}

model IngestCursor {
  id        String    @id @default(cuid())
  tenantId  String
  source    String // "shopify"
  resource  String // "orders" | "products" | "inventory"
  cursor    DateTime?
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, source, resource])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  webhookId  String   @unique // X-Shopify-Webhook-Id
  topic      String
  shop       String
  receivedAt DateTime @default(now())
}

model InventorySnapshot {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  date      DateTime // UTC midnight of the snapshot day
  onHand    Float

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([tenantId, date])
}

model PurchaseOrder {
  id          String    @id @default(cuid())
  tenantId    String
  supplierId  String
  poNumber    String
  status      String    @default("draft") // draft | sent
  currency    String    @default("KES")
  subtotalKes Float     @default(0)
  createdAt   DateTime  @default(now())
  sentAt      DateTime?

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  lines    PurchaseOrderLine[]
  orders   Order[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
}

model PurchaseOrderLine {
  id              String @id @default(cuid())
  purchaseOrderId String
  productId       String
  sku             String
  title           String
  quantity        Int
  unitCostKes     Float
  lineTotalKes    Float

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

// Stored forecast-accuracy run (G6) — the monthly backtest cron writes one row so
// accuracy is tracked over time and the drop-detector (G7) can compare runs.
// tenantId-only (no relation), mirroring IngestCursor/WebhookEvent.
model BacktestRun {
  id         String   @id @default(cuid())
  tenantId   String
  runDate    DateTime @default(now())
  mae        Float
  bias       Float
  mape       Float?
  sampleSize Int
  tag        String? // "holdout" | "walkforward"

  @@index([tenantId, runDate])
}

// Weekly shelf-vs-system spot-check (G8): the app prompts a count of 5 SKUs to
// catch drift between physical shelves and the app's on-hand.
model SpotCheck {
  id         String    @id @default(cuid())
  tenantId   String
  productId  String
  weekKey    String // ISO week, e.g. "2026-W24" — one set of prompts per week
  systemQty  Float // on-hand the app believed when prompting
  countedQty Float? // what the owner physically counted (null until done)
  createdAt  DateTime  @default(now())
  countedAt  DateTime?

  @@index([tenantId, weekKey])
}

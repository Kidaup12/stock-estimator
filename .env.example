# ─────────────────────────────────────────────────────────────────────────────
# Wezesha Restock OS — environment variables
# Copy to .env (gitignored). Fill in the values for the phase you're working on.
# ─────────────────────────────────────────────────────────────────────────────

# ── Phase 1: Database (REQUIRED to run the app) ──────────────────────────────
# Supabase Postgres — use the POOLER (transaction mode, port 6543) for runtime
# Format: postgres://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Local dev: postgresql://wezesha:wezesha_dev@localhost:5433/wezesha?schema=public
DATABASE_URL=""

# Supabase Postgres direct connection — required by `prisma migrate` (port 5432)
# Format: postgresql://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres
# Local dev: same as DATABASE_URL
DIRECT_URL=""

# ── Phase 2: Supabase Auth (TODO — Phase 2) ──────────────────────────────────
# Sign-up via email + magic link, optional Google OAuth.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Field-level encryption key for stored OAuth tokens (Shopify, QB).
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=""

# ── Phase 3: Shopify Integration (TODO — Phase 3) ────────────────────────────
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SCOPES="read_products,read_inventory,read_orders,write_draft_orders"
SHOPIFY_APP_URL=""

# ── Phase 3: Odoo Integration (TODO — Phase 3) ───────────────────────────────
ODOO_BASE_URL=""
ODOO_API_KEY=""

# ── Phase 4: QuickBooks Online (TODO — Phase 4) ──────────────────────────────
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_REDIRECT_URI=""
QUICKBOOKS_ENVIRONMENT="sandbox"  # or "production"

# ── Phase 4: Resend (PO email delivery) (TODO — Phase 4) ─────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="orders@wezesha.app"

# ── Phase 5: Python Forecast Sidecar (TODO — Phase 5) ────────────────────────
FORECAST_SIDECAR_URL=""
# Shared JWT secret for sidecar auth.
# Generate: openssl rand -base64 32
FORECAST_SIDECAR_SECRET=""

# ── Phase 5: Sentry observability (TODO — Phase 5) ───────────────────────────
SENTRY_DSN_WEB=""
SENTRY_DSN_SIDECAR=""
